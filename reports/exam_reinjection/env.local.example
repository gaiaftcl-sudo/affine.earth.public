# Exam miss → reinject → C4 lock (local Franklin only). Copy to env.local and source.
# Never Kaggle. No Keychain.

# Primary OpenAI-compatible chat endpoint (LM Studio / llama-server)
export EXAM_REINJECT_BASE_URL="${EXAM_REINJECT_BASE_URL:-http://127.0.0.1:8080/v1}"

# If primary stalls (read timeout), library retries this fallback automatically
export EXAM_REINJECT_FALLBACK_BASE_URL="${EXAM_REINJECT_FALLBACK_BASE_URL:-http://127.0.0.1:1234/v1}"

# Optional aliases also accepted: OPENAI_BASE_URL / HLE_LOCAL_BASE_URL
# export OPENAI_BASE_URL=http://127.0.0.1:8080/v1

export EXAM_REINJECT_MODEL="${EXAM_REINJECT_MODEL:-qwen/qwen3.6-35b-a3b}"
export OPENAI_API_KEY="${OPENAI_API_KEY:-uum8d-exam-reinject}"

# Compact prompts + json_schema: 300s is enough; raise if thinking models stall
export EXAM_REINJECT_TIMEOUT="${EXAM_REINJECT_TIMEOUT:-300}"
export EXAM_REINJECT_MAX_TOKENS="${EXAM_REINJECT_MAX_TOKENS:-2048}"

# Live daemon: forbids --dry-run mixed writers on the same state dir
export EXAM_REINJECT_LIVE=1

# Launch:
#   set -a; source reports/exam_reinjection/env.local; set +a
#   nohup ./bin/run-exam-reinjection-loop.sh --daemon --interval-seconds 30 \
#     --mastery none --tracks arc2 --per-track-limit 1 \
#     > reports/exam_reinjection/daemon.log 2>&1 &
