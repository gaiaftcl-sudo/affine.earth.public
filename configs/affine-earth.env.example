# The endpoint must be the full OpenAI-compatible chat-completions URL.
# Do not place API keys in this file when it is tracked.
export AFFINE_ENDPOINT="https://affine.earth/v1/chat/completions"
export AFFINE_MODEL="replace-with-published-model-id"
export AFFINE_HEALTHCHECK_URL="https://affine.earth/language-invariant/healthz"

