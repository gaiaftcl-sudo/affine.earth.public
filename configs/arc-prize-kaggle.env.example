# Copy outside git, then set the real value in your shell:
#   set -a; source /secure/path/arc-prize-kaggle.env; set +a
KAGGLE_API_TOKEN=REPLACE_WITH_KAGGLE_API_TOKEN

# Official Kaggle input mount used inside the air-gapped notebook runtime.
ARC_PRIZE_INPUT_DIR=/kaggle/input/arc-prize-2026-arc-agi-3

# Optional local-only Affine adapter. It receives a JSON request on stdin and
# must write one ARC color grid JSON value to stdout.
AFFINE_ARC_SOLVER_COMMAND=
