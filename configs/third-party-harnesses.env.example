# Copy to .env.third-party-harnesses (gitignored), edit, then either:
#   source .env.third-party-harnesses
#   ./bin/run-official-leaderboard-harnesses.sh --harness lm-eval
# or:
#   AFFINE_HARNESS_ENV_FILE=.env.third-party-harnesses \
#     ./bin/run-official-leaderboard-harnesses.sh --harness lm-eval
#
# HARD FACT (2026-07-20): https://affine.earth/v1 returns an HTML SPA, not
# OpenAI-compatible JSON. Do not leave AFFINE_HARNESS_ENDPOINT on that URL
# until /models returns JSON. language-invariant/healthz is liveness only.
#
# Until live /v1 is JSON, point at a real OpenAI-compatible server, or for
# local wiring only (NOT a public score claim):
#   python3 llm_llvm_bench/server/affine_v1_interceptor.py 8000
#   export AFFINE_HARNESS_ENDPOINT="http://127.0.0.1:8000/v1"

export AFFINE_HARNESS_MODEL="replace-with-model-id-from-v1-models"
export AFFINE_HARNESS_ENDPOINT="http://127.0.0.1:8000/v1"
export AFFINE_HARNESS_API_KEY="replace-with-provider-key"

# Aliases accepted by bin/run-official-leaderboard-harnesses.sh:
# export OPENAI_BASE_URL="$AFFINE_HARNESS_ENDPOINT"
# export AFFINE_BASE_URL="$AFFINE_HARNESS_ENDPOINT"
# export AFFINE_OPENAI_BASE_URL="$AFFINE_HARNESS_ENDPOINT"
# export OPENAI_API_KEY="$AFFINE_HARNESS_API_KEY"

# Upstream checkouts (cloned under harnesses/, gitignored).
export LM_EVAL_DIR="harnesses/lm-evaluation-harness"
export BIGCODE_HARNESS_DIR="harnesses/bigcode-evaluation-harness"
export FASTCHAT_DIR="harnesses/FastChat"

# EleutherAI lm-evaluation-harness — pin: lm-eval==0.4.7
export LM_EVAL_TASKS="mmlu,gsm8k"
export LM_EVAL_NUM_FEWSHOT="0"
export LM_EVAL_BATCH_SIZE="1"
export LM_EVAL_CONCURRENCY="1"
export LM_EVAL_MAX_RETRIES="3"
export LM_EVAL_OUTPUT_PATH="reports/third_party/lm_eval"

# BigCode bigcode-evaluation-harness — pin: git tag v0.1.0
export BIGCODE_TASKS="humaneval,mbpp"
export BIGCODE_TEMPERATURE="0.2"
export BIGCODE_N_SAMPLES="20"
export BIGCODE_BATCH_SIZE="1"
export BIGCODE_METRIC_OUTPUT_PATH="reports/third_party/bigcode/results.json"
# Required unless BIGCODE_GENERATIONS_PATH is set (upstream has no native OpenAI API mode):
# export BIGCODE_LOCAL_MODEL="/absolute/path/or/huggingface-model-id"
# export BIGCODE_GENERATIONS_PATH="/absolute/path/to/real-generations.json"

# LMSYS FastChat MT-Bench — pin: fschat==0.2.36
export FASTCHAT_BENCH="mt_bench"
export FASTCHAT_PARALLEL="1"
export FASTCHAT_ANSWER_FILE="reports/third_party/fastchat/mt-bench-answers.jsonl"
# export MTBENCH_RUN_JUDGE="1"   # only with real judge credentials
export MTBENCH_JUDGE_PARALLEL="1"

# ---------------------------------------------------------------------------
# Hardest / Open AGI — bin/run-open-agi-harnesses.sh
# Registry: configs/open-agi-harnesses.yaml
# Docs: docs/OPEN_AGI_FRAMEWORKS.md
# ---------------------------------------------------------------------------

# GPQA via lm-eval (task must exist in installed lm-eval pin)
export GPQA_TASKS="gpqa_diamond_zeroshot"
export GPQA_NUM_FEWSHOT="0"
export GPQA_BATCH_SIZE="1"
export GPQA_OUTPUT_PATH="reports/third_party/open_agi/gpqa"

# Humanity's Last Exam — checkout: git clone https://github.com/centerforaisafety/hle.git harnesses/hle
export HLE_HARNESS_DIR="harnesses/hle"
export HLE_DATASET="cais/hle"
export HLE_MAX_COMPLETION_TOKENS="8192"
export HLE_NUM_WORKERS="4"
export HLE_OUTPUT_DIR="reports/third_party/open_agi/hle"
# export HF_TOKEN="hf_..."          # required — gated HF dataset
# export HLE_MAX_SAMPLES="3"        # optional smoke
# export HLE_RUN_JUDGE="1"          # after predictions exist

# ARC-AGI / ARC Prize — checkout: git clone https://github.com/arcprize/arc-agi-benchmarking.git harnesses/arc-agi-benchmarking
export ARC_AGI_HARNESS_DIR="harnesses/arc-agi-benchmarking"
# export ARC_AGI_CONFIG="gpt-4o-2024-11-20"   # must match models.yml in checkout
# export ARC_AGI_DATA_DIR="/absolute/path/to/arc/tasks"
export ARC_AGI_SUBMISSION_DIR="reports/third_party/open_agi/arc_agi/submissions"
export ARC_AGI_LOG_LEVEL="INFO"
export ARC_AGI_PREFLIGHT_OPENAI="1"

# GAIA via Inspect AI — pip install inspect-ai inspect-evals (+ Docker for tools)
export GAIA_TASK="inspect_evals/gaia"
export GAIA_LOG_DIR="reports/third_party/open_agi/gaia"
export GAIA_REQUIRE_DOCKER="1"
# export GAIA_INSPECT_MODEL="openai/${AFFINE_HARNESS_MODEL}"

# SWE-bench / LiveCodeBench — wrappers always exit 3 (NEEDS_UPSTREAM); no fake scores.
